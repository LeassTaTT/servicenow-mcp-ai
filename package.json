{
  "name": "sincronia-mcp",
  "version": "1.0.0",
  "description": "ServiceNow MCP server: 49 tools over the full REST surface (Table, Aggregate, Attachment, Import Set, Batch, CMDB/IRE, Catalog, Change, Knowledge, Email) with script intelligence, Mermaid generators and a two-axis policy model.",
  "type": "module",
  "bin": {
    "sincronia-mcp": "./bin/sincronia-mcp.cjs"
  },
  "main": "./build/index.js",
  "files": [
    "build",
    "bin"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node -e \"try{require('fs').chmodSync('build/index.js',0o755)}catch{}\"",
    "watch": "tsc --watch",
    "start": "node build/index.js",
    "dev": "node --watch build/index.js",
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js",
    "docs:readme": "node scripts/readme-tools.mjs",
    "test:full": "npm run build && node --test test/*.test.js",
    "gen:manifest": "node scripts/gen-manifest.mjs",
    "verify": "npm run build && npm run lint && npm run format:check && node --test test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "fast-check": "^4.8.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "servicenow",
    "llm",
    "ai",
    "rest"
  ]
}
