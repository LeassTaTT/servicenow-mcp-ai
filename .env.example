# ServiceNow connection credentials.
# Copy this file to .env and fill in your values, or use the
# `servicenow_set_credentials` tool which writes them here automatically.

# Instance host. Accepts "dev12345" or "dev12345.service-now.com" or a full URL.
SN_INSTANCE=your-instance.service-now.com

# ServiceNow username.
SN_USER=your.username@example.com

# ServiceNow password.
SN_PASSWORD=your-password

# --- Optional tuning (defaults shown, all commented out) ---
# Per-request timeout in milliseconds.
# SN_TIMEOUT_MS=30000
# Retries for transient failures (429/503 any method; 502/504 and network errors on GET).
# SN_MAX_RETRIES=2
# Hard cap on records returned when a query uses fetchAll.
# SN_MAX_RECORDS=10000
# Max characters in a query result before the record set is truncated.
# SN_MAX_RESULT_CHARS=100000
# Comma-separated host allowlist. When set, only these hosts (or their
# subdomains) are allowed; this also lifts the default internal-host block.
# SN_ALLOWED_HOSTS=service-now.com

# --- Authentication (defaults to Basic; set OAuth client id to use OAuth) ---
# Force a mode explicitly: basic | oauth. Auto-detects oauth when SN_OAUTH_CLIENT_ID is set.
# SN_AUTH=basic
# OAuth 2.0 client credentials registered in ServiceNow (Application Registry).
# SN_OAUTH_CLIENT_ID=
# SN_OAUTH_CLIENT_SECRET=
# Grant type: password (uses SN_USER/SN_PASSWORD), client_credentials, or refresh_token.
# SN_OAUTH_GRANT=password
# Refresh token, required only for the refresh_token grant.
# SN_OAUTH_REFRESH_TOKEN=

# --- Access policy (least privilege) ---
# Comma-separated allowlist of tables; when set, only these are reachable.
# SN_TABLES_ALLOW=incident,change_request
# Comma-separated denylist of tables; always wins over the allowlist.
# SN_TABLES_DENY=sys_user,sys_user_has_role
# Read-only mode: refuse every create/update/delete when truthy.
# SN_READONLY=false

# --- Observability ---
# Log level on stderr: error | warn | info | debug.
# SN_LOG_LEVEL=info

# --- Tool packages ---
# Comma/space-separated profiles or package names to register.
# Profiles: core (default) = table,schema,aggregate,attachment; all = everything.
# Packages: table, schema, aggregate, attachment, importset, batch,
#           catalog, change, knowledge, cmdb, scripts, docs.
# The admin tools (set_credentials, get_status) are always registered.
# SN_TOOL_PACKAGES=core
# Packages to exclude even when enabled above. Note: SN_TABLES_DENY does NOT
# cover the plugin APIs (catalog/change/knowledge…) — this is how you block them.
# SN_PACKAGES_DENY=change,catalog
# Packages registered with their read tools only (write tools are dropped).
# SN_PACKAGES_READONLY=cmdb

# --- Self-documentation (docs package) ---
# Directory the docs tools read/write Markdown in (default docs/instance).
# SN_DOCS_DIR=docs/instance

# --- Configuration file location ---
# Explicit path to the env file to read/write. Otherwise the server uses
# ~/.config/sincronia-mcp/.env (if present) or this project-root .env.
# SN_ENV_FILE=
