# ServiceNow connection credentials.
# Copy this file to .env and fill in your values, or use the
# `servicenow_set_credentials` tool which writes them here automatically.

# Instance host. Accepts "dev12345" or "dev12345.service-now.com" or a full URL.
SN_INSTANCE=your-instance.service-now.com

# ServiceNow username.
SN_USER=your.username@example.com

# ServiceNow password.
SN_PASSWORD=your-password

# --- Optional tuning (defaults shown, all commented out) ---
# Per-request timeout in milliseconds.
# SN_TIMEOUT_MS=30000
# Retries for transient failures (429/503 any method; 502/504 and network errors on GET).
# SN_MAX_RETRIES=2
# Hard cap on records returned when a query uses fetchAll.
# SN_MAX_RECORDS=10000
# Max characters in a query result before the record set is truncated.
# SN_MAX_RESULT_CHARS=100000
# Comma-separated host allowlist for custom or sovereign-cloud domains. When set,
# only these hosts (or their subdomains) are allowed and the internal-host block
# is lifted. When unset, only *.service-now.com instances are reachable.
# SN_ALLOWED_HOSTS=service-now.com

# --- Authentication (defaults to Basic) ---
# Method: basic | oauth | apikey | token | none (cert-only mTLS).
# Auto-detected from the keys present: API key -> bearer -> OAuth -> Basic.
# SN_AUTH=basic
#
# API Key (ServiceNow Inbound API Keys) -> sent as the x-sn-apikey header:
# SN_API_KEY=
# A pre-obtained bearer token, used verbatim:
# SN_BEARER_TOKEN=
# OAuth client credentials registered in ServiceNow (Application Registry).
# SN_OAUTH_CLIENT_ID=
# SN_OAUTH_CLIENT_SECRET=
#
# RECOMMENDED — OAuth 2.1 Authorization Code + PKCE. Register an "Authorization
# Code" endpoint with this loopback redirect, then run:  npx servicenow-mcp-ai login
# It stores SN_OAUTH_REFRESH_TOKEN and sets SN_OAUTH_GRANT=refresh_token for you.
# SN_OAUTH_REDIRECT_URI=http://localhost:53682/callback
# SN_OAUTH_SCOPE=
#
# Grant type: refresh_token (recommended, set by `login`), client_credentials,
# jwt_bearer, or password (DEPRECATED — ROPC, disabled on many instances).
# SN_OAUTH_GRANT=refresh_token
# Refresh token for the refresh_token grant (obtained by `login`).
# SN_OAUTH_REFRESH_TOKEN=
#
# OAuth JWT-bearer grant (service account, no password). PEM private key + claims;
# the public cert is registered on the ServiceNow JWT provider.
# SN_OAUTH_GRANT=jwt_bearer
# SN_OAUTH_JWT_KEY=            # or SN_OAUTH_JWT_KEY_FILE=/path/key.pem
# SN_OAUTH_JWT_SUB=           # subject/user (default: SN_USER)
# SN_OAUTH_JWT_ISS=           # default: client id
# SN_OAUTH_JWT_AUD=           # default: https://<host>/oauth_token.do

# --- Mutual TLS (client certificate) — needs the optional `undici` package ---
# Presents a client cert on the TLS handshake; ServiceNow maps it to a user.
# Combine with any method above, or use SN_AUTH=none for cert-only.
# SN_TLS_CLIENT_CERT=         # or SN_TLS_CLIENT_CERT_FILE=/path/cert.pem
# SN_TLS_CLIENT_KEY=          # or SN_TLS_CLIENT_KEY_FILE=/path/key.pem
# SN_TLS_CA=                  # or SN_TLS_CA_FILE=/path/ca.pem
# SN_TLS_REJECT_UNAUTHORIZED=true

# --- Named connection profiles (multi-instance) ---
# The bare SN_INSTANCE/SN_USER/SN_PASSWORD above are the 'default' profile.
# Define more instances with prefixed keys; switch via SN_ACTIVE_PROFILE or
# the servicenow_use_instance tool.
# SN_PROFILE_DEV_INSTANCE=dev12345.service-now.com
# SN_PROFILE_DEV_USER=dev.user
# SN_PROFILE_DEV_PASSWORD=secret
# SN_ACTIVE_PROFILE=default

# --- Access policy (least privilege) ---
# Comma-separated allowlist of tables; when set, only these are reachable.
# SN_TABLES_ALLOW=incident,change_request
# Comma-separated denylist of tables; always wins over the allowlist.
# SN_TABLES_DENY=sys_user,sys_user_has_role
# Read-only mode: refuse every create/update/delete when truthy.
# SN_READONLY=false
# Plan-and-apply write mode (DF-2): plan (default) previews a write as a
# before/after diff without mutating; apply executes. A tool's apply:true
# forces execution for a single call.
# SN_WRITE_MODE=plan
# Field redaction (DF-5): mask these field values before records reach the model.
# SN_REDACT_FIELDS=email,phone,ssn
# Also mask email/phone/national-id patterns inside any string value.
# SN_REDACT_PII=false

# --- Observability ---
# Log level on stderr: error | warn | info | debug.
# SN_LOG_LEVEL=info

# --- Performance ---
# TTL (seconds) for the schema reads cache (list_tables/describe_table/
# get_cmdb_meta); 0 disables caching.
# SN_SCHEMA_CACHE_TTL_SEC=300
# Maximum parallel HTTP requests to the instance.
# SN_MAX_CONCURRENT=4

# --- Output shaping (token savings; both default to the lean variant) ---
# Include reference field 'link' URLs in results (default: excluded).
# SN_INCLUDE_REF_LINKS=false
# Pretty-print JSON results (default: compact).
# SN_RESULT_PRETTY=false

# --- Tool packages ---
# Comma/space-separated profiles or package names to register.
# Profiles: core (default) = table,schema,aggregate,attachment; all = everything.
# Packages: table, schema, aggregate, attachment, importset, batch,
#           catalog, change, knowledge, cmdb, scripts, docs, email.
# The admin tools (set_credentials, get_status) are always registered.
# SN_TOOL_PACKAGES=core
# Packages to exclude even when enabled above. Note: SN_TABLES_DENY does NOT
# cover the plugin APIs (catalog/change/knowledge…) — this is how you block them.
# SN_PACKAGES_DENY=change,catalog
# Packages registered with their read tools only (write tools are dropped).
# SN_PACKAGES_READONLY=cmdb

# --- Self-documentation (docs package) ---
# Directory the docs tools read/write Markdown in (default docs/instance).
# SN_DOCS_DIR=docs/instance

# --- Configuration file location ---
# Explicit path to the env file to read/write. Otherwise the server uses
# ~/.config/sincronia-mcp/.env (if present) or this project-root .env.
# SN_ENV_FILE=
